# =============================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this to .env and fill in your values
# =============================================

# Server
PORT=3000

# Database — Railway MySQL (production)
# MYSQL_URL is auto-provided by Railway when you add a MySQL service
# MYSQL_URL=mysql://root:password@host:port/railway

# Database — Local MySQL / XAMPP (development)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=banyuanyar_trip

# JWT Authentication
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=24h

# Cloudinary — Cloud Image Storage
# Sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
